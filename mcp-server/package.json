{
  "name": "10x-development-team",
  "version": "2.0.0",
  "description": "MCP server for the 10x Development Team — exposes app-building skills as tools for any AI client",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "10x-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "postinstall": "node scripts/postinstall.js || true",
    "prebuild:package": "node scripts/bundle-plugin.js",
    "build:package": "npm run prebuild:package && tsc",
    "prepublishOnly": "npm run build:package",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "development",
    "code-generation",
    "10x"
  ],
  "author": "10x-Anit",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "better-sqlite3": "^11.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "files": [
    "dist",
    "plugin",
    "scripts",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  }
}
