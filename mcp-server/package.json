{
  "name": "10x-development-team",
  "version": "3.1.0",
  "description": "AI-powered multi-agent development team — builds stunning apps with 3D scenes, scroll animations, glassmorphism, particle effects, and production-grade UI",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "10x-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "postinstall": "node scripts/postinstall.cjs || true",
    "prebuild:package": "node scripts/bundle-plugin.cjs",
    "build:package": "npm run prebuild:package && tsc",
    "prepublishOnly": "npm run build:package",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "development",
    "code-generation",
    "10x",
    "3d",
    "three-js",
    "react-three-fiber",
    "gsap",
    "scroll-animations",
    "glassmorphism",
    "particles",
    "webgl",
    "design-system",
    "multi-agent"
  ],
  "author": "10x-Anit",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "files": [
    "dist",
    "plugin",
    "scripts",
    "README.md"
  ],
  "peerDependencies": {
    "playwright": ">=1.40.0",
    "@playwright/mcp": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    },
    "@playwright/mcp": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  }
}
